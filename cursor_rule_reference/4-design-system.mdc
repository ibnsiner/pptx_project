```

### 지표별 색상 가이드 (WABC, FX Loss 등)
```typescript
// 점수 범위별 색상
function getScoreColor(score: number): string {
  if (score >= 4.5) return 'text-green-600'      // 우수
  if (score >= 4.0) return 'text-blue-600'       // 양호
  if (score >= 3.5) return 'text-yellow-600'     // 보통
  if (score >= 3.0) return 'text-orange-600'     // 주의
  return 'text-red-600'                          // 미흡
}

// Badge variant
function getScoreBadgeVariant(score: number): 'success' | 'info' | 'warning' | 'error' {
  if (score >= 4.5) return 'success'
  if (score >= 4.0) return 'info'
  if (score >= 3.5) return 'warning'
  return 'error'
}
```

