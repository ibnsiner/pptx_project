# =============================================================
# 이 파일을 복사해서 .env.local 로 저장한 뒤 값을 채우세요.
# cp .env.example .env.local   (Mac/Linux)
# copy .env.example .env.local (Windows)
#
# .env.local 은 git에 올라가지 않습니다 (비밀 유지).
# 이 파일(.env.example)만 git에 올라갑니다.
# =============================================================


# ── 1. Supabase 프로젝트 설정 ─────────────────────────────
# 위치: Supabase Dashboard → Settings → API
#
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>


# ── 2. 관리자 이메일 ─────────────────────────────────────
# 쉼표로 구분. 해당 이메일로 로그인하면 /admin 경로 접근 가능.
#
ADMIN_EMAILS=you@example.com


# ── 3. Parser API 주소 ───────────────────────────────────
# 로컬 개발: 기본값 그대로 사용 (변경 불필요)
# 서버 배포 시: parser-api 서버의 실제 URL로 변경
#
PARSER_API_URL=http://127.0.0.1:8010
NEXT_PUBLIC_PARSER_API_URL=http://127.0.0.1:8010


# ── 4. Database URL ──────────────────────────────────────
# 위치: Supabase Dashboard → Settings → Database → Connection String
#       → Transaction(Pooler) 탭에서 복사
#
# 비밀번호에 특수문자가 있으면 URL 인코딩 필요:
#   @  →  %40
#   !  →  %21
#   #  →  %23
#   $  →  %24
#
# 예시 (실제 값으로 교체):
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true


# ── 5. Supabase Service Role Key (서버 전용) ──────────────
# 위치: Supabase Dashboard → Settings → API → service_role key
# 절대 브라우저에 노출하지 마세요 (NEXT_PUBLIC_ 접두사 금지).
#
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>


# ── 6. OpenAI API Key (RAG·임베딩용, 선택) ───────────────
# 위치: https://platform.openai.com/api-keys
# 드래프트(검수) 단계에서는 없어도 됩니다.
# 최종 등록(publish) 및 AI 채팅 기능 사용 시 필요.
#
OPENAI_API_KEY=sk-...
