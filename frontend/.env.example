# Supabase (browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin allowlist (comma-separated emails). Matches project_info ADMIN_EMAILS.
ADMIN_EMAILS=

# Parser microservice: Next `/api/parse-pptx` proxies here (server-side).
PARSER_API_URL=http://127.0.0.1:8010
# Optional: legacy direct browser call (not used if upload page uses proxy only)
NEXT_PUBLIC_PARSER_API_URL=http://127.0.0.1:8010

# Prisma: use Transaction pooler URI with ?pgbouncer=true
# If password contains @ or !, URL-encode it (e.g. @ -> %40, ! -> %21)
DATABASE_URL=

# Server-only (later: publish, embeddings, service tasks)
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
