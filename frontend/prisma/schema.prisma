generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lecture {
  id          String         @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  author      String
  tags        String[]       @default([])
  createdAt   DateTime       @default(now())
  slides      Slide[]
  chunks      LectureChunk[]
}

model Slide {
  id          String         @id @default(cuid())
  slideNumber Int
  lectureId   String
  lecture     Lecture        @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  elements    Json
  chunks      LectureChunk[]
}

model LectureChunk {
  id          String   @id @default(cuid())
  lectureId   String
  lecture     Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  slideId     String?
  slide       Slide?   @relation(fields: [slideId], references: [id], onDelete: SetNull)
  slideNumber Int
  chunkIndex  Int
  content     String
  tokenCount  Int?
  createdAt   DateTime @default(now())

  @@unique([lectureId, slideNumber])
  @@index([lectureId])
}
