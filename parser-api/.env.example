# =============================================================
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.
# cp .env.example .env   (Mac/Linux)
# copy .env.example .env (Windows)
#
# parser-api는 대부분의 경우 기본값으로 동작합니다.
# Supabase Storage에 이미지를 업로드하려면 아래 값을 채우세요.
# =============================================================


# ── Supabase Storage (슬라이드 이미지 업로드, 선택) ──────
# 비어 있으면 이미지를 base64 data URL로 응답에 포함합니다.
# 프로덕션 배포 시 Storage를 쓰는 것을 권장합니다.
#
# 위치: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
STORAGE_BUCKET=lecture-assets


# ── 래스터 설정 (선택, 기본값으로 대부분 OK) ────────────
# PPTX_SLIDE_RASTER=1              # 0 으로 설정하면 래스터 비활성화
# PPTX_RASTER_MAX_LONG_EDGE=1280   # 슬라이드 이미지 최대 픽셀 (320~4096)
# PPTX_RASTER_JPEG_QUALITY=82      # JPEG 품질 (50~95)
# PPTX_LIBREOFFICE_PATH=           # LibreOffice 실행 파일 경로 (기본 위치 아닌 경우)
